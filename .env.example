# Core app settings
SECRET_KEY=replace-with-a-random-secret
USER_AGENT=ProteinMutationWorkbench/0.1 (replace-with-contact-email)
REQUEST_TIMEOUT_SECONDS=20
PREDICTOR_TIMEOUT_SECONDS=180
ANALYSIS_WORKDIR=/tmp/protein-mutation-workbench

# Safe Vercel default:
# Leave this blank to disable predictors that rely on local binaries or slow external jobs.
# Optional remote-only set: interproscan,hmmer,phobius
ENABLED_PREDICTOR_KEYS=
ENABLE_CURATED_FALLBACK=false
EBI_JOB_EMAIL=you@example.org

# Optional API endpoint overrides
UNIPROT_BASE_URL=https://rest.uniprot.org
INTERPRO_API_BASE_URL=https://www.ebi.ac.uk/interpro/api
EBI_PROTEINS_API_BASE_URL=https://www.ebi.ac.uk/proteins/api
ENSEMBL_REST_BASE_URL=https://rest.ensembl.org
NCBI_DATASETS_BASE_URL=https://api.ncbi.nlm.nih.gov/datasets/v2
NCBI_EUTILS_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils
MAVEDB_API_BASE_URL=https://api.mavedb.org/api/v1
